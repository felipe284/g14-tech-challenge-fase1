        {
          "name": "Login - POST /api/v1/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.userId) {",
                  "    pm.collectionVariables.set('userId', json.userId);",
                  "    console.log('userId encontrado', json.userId);",
                  "  } else {",
                  "    console.warn('Response não encontrou userId');",
                  "  }",
                  "} catch (e) {",
                  "  console.error('Erro ao atualizar userId:', e);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"joao.silva\",\n  \"senha\": \"123456789\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
